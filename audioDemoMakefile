# Derleyici
CXX = g++

# C++ Standardı
CXXFLAGS = -std=c++17 -O3

# Temel Yollar (Conda ve Torch klasörleri)
CONDA_ENV = /home/orin2/miniconda3/envs/libtorch
TORCH_ROOT = $(CONDA_ENV)/lib/python3.10/site-packages/torch
# İşte eksik olan o "gizli" klasör:
TORCH_LIBS = $(CONDA_ENV)/lib/python3.10/site-packages/torch.libs

# Header dosyalarının (include) aranacağı yollar
INCLUDES = \
	-I$(TORCH_ROOT)/include \
	-I$(TORCH_ROOT)/include/torch/csrc/api/include

# Kütüphanelerin (.so dosyalarının) aranacağı yollar
LIB_DIRS = \
	-L$(TORCH_ROOT)/lib \
	-L$(TORCH_LIBS) \
	-L$(CONDA_ENV)/lib

# Çalışma anında (runtime) kütüphanelerin bulunabilmesi için RPATH ayarları
LDFLAGS = \
	-Wl,-rpath,$(TORCH_ROOT)/lib \
	-Wl,-rpath,$(TORCH_LIBS) \
	-Wl,-rpath,$(CONDA_ENV)/lib

# Bağlanacak kütüphaneler (LibTorch)
LIBS = -ltorch -ltorch_cpu -lc10

# Derleme kuralları (Eğer undefined reference hatası alırsan burayı 0 yap)
ABI_FLAG = -D_GLIBCXX_USE_CXX11_ABI=1

# Hedef dosya adı
TARGET = audio_reader
SRC = demo.cpp

all: $(TARGET)

$(TARGET): $(SRC)
	$(CXX) $(CXXFLAGS) $(ABI_FLAG) $(INCLUDES) $(SRC) -o $(TARGET) $(LIB_DIRS) $(LDFLAGS) $(LIBS)

clean:
	rm -f $(TARGET)